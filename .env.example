# Copy this file to .env and fill in your own key.
# Never commit .env.
NEWSAPI_KEY=your_newsapi_key_here

# Optional defaults.
# NewsAPI country examples: us, gb, cn, jp, de, fr, au
NEWS_MCP_DEFAULT_COUNTRY=us
NEWS_MCP_DEFAULT_LANGUAGE=en

# Optional advanced paths. Defaults work for this repo.
# NEWS_MCP_RSS_CONFIG=config/rss_sources.json
# NEWS_MCP_PREFERENCES=.news_mcp_preferences.json

# Optional email delivery. Gmail example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_gmail@gmail.com
# SMTP_PASSWORD=your_google_app_password
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# EMAIL_FROM=your_gmail@gmail.com
# EMAIL_TO=your_private_inbox@gmail.com
# EMAIL_TEMPLATE_PATH=templates/news_brief_email.html
